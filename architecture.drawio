        <mxCell id="httpclient" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;HttpClient&lt;/b&gt;  (Protocol)&lt;br&gt; Structural typing — any obj with .get()&lt;br&gt; Impl: requests.Session (shared)&lt;br&gt; Enables DI &amp; test mocking" vertex="1">
