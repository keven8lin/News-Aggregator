        <mxCell id="s1_header" parent="1" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=left;verticalAlign=middle;spacingLeft=10;fontSize=13;fontStyle=1;rounded=1;" value="① CONFIGURATION  (config.py · providers/config.py)" vertex="1">
          <mxGeometry height="28" width="860" x="15" as="geometry" />
        </mxCell>
        <mxCell id="fetchconfig" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;FetchConfig&lt;/b&gt;  providers/config.py&lt;br&gt; Global defaults (used unless provider override is non-None):&lt;br&gt; rate_limit_seconds=1.0 · page_size=10 · timeout_seconds=10.0 · max_retry_attempts=3 · backoff_seconds=2.0&lt;br&gt; gnews_* / spaceflight_* nullable fields override global per-provider&lt;br&gt; &lt;i&gt;fetch_config.get(field, provider) resolves effective value&lt;/i&gt;" vertex="1">
          <mxGeometry height="90" width="460" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="settings" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;Settings&lt;/b&gt;  config.py&lt;br&gt; gnews_api_key ← GNEWS_API_KEY (env / .env)&lt;br&gt; Built-in .env parser — no external deps&lt;br&gt; Frozen dataclass — immutable at runtime" vertex="1">
          <mxGeometry height="90" width="360" x="515" y="50" as="geometry" />
        </mxCell>
        <mxCell id="s2_header" parent="1" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=left;verticalAlign=middle;spacingLeft=10;fontSize=13;fontStyle=1;rounded=1;" value="② DATA CONTRACTS / MODELS  (models.py)" vertex="1">
          <mxGeometry height="28" width="860" x="20" y="175" as="geometry" />
        </mxCell>
        <mxCell id="newsquery" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;NewsQuery&lt;/b&gt; — input contract&lt;br&gt; q · language · country · category&lt;br&gt; from_date / to_date (datetime | None)&lt;br&gt; page_size  ← from FetchConfig&lt;br&gt; sort_by = publishedAt" vertex="1">
          <mxGeometry height="100" width="260" x="30" y="213" as="geometry" />
        </mxCell>
        <mxCell id="spaceflightmodel" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;SpaceFlight&lt;/b&gt; — normalized article (provider-agnostic output model)&lt;br&gt; provider · provider_article_id · title · url&lt;br&gt; summary · content · authors: list[str]&lt;br&gt; published_at · source_name · language · category&lt;br&gt; raw: dict  ← original API payload preserved for debugging / future fields" vertex="1">
