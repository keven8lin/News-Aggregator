        <mxCell id="ratelimiter" parent="1" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;RateLimiter&lt;/b&gt;&lt;br&gt; Enforces min delay between successive calls&lt;br&gt; delay ← FetchConfig.get(rate_limit_seconds, provider)&lt;br&gt; Separate instance per provider&lt;br&gt; wait() sleeps remaining time since last call" vertex="1">
