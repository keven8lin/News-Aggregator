    <!-- TITLE -->
    <mxCell id="title" value="&lt;b&gt;News Aggregation Pipeline — System Design&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="20" width="1100" height="40" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         SECTION 1: CONFIGURATION
    ═══════════════════════════════════════════ -->
    <mxCell id="cfg_bg" value="&lt;b&gt;1. CONFIGURATION&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;fontStyle=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="80" y="70" width="960" height="100" as="geometry" />
    </mxCell>

    <mxCell id="settings" value="&lt;b&gt;Settings&lt;/b&gt; (config.py)&lt;br&gt;Frozen dataclass — loads .env then env vars&lt;br&gt;gnews_api_key (required)&lt;br&gt;newsapi_key = '' (stub for future provider)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="110" y="85" width="240" height="72" as="geometry" />
    </mxCell>

    <mxCell id="fetchcfg" value="&lt;b&gt;FetchConfig&lt;/b&gt; (providers/config.py)&lt;br&gt;Frozen dataclass — global defaults + per-provider overrides&lt;br&gt;rate_limit=1.0s · page_size=10 · timeout=10s&lt;br&gt;max_retry=3 · backoff=2.0s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="375" y="85" width="310" height="72" as="geometry" />
    </mxCell>

    <mxCell id="dotenv_note" value="Priority: ENV VAR &gt; .env file&lt;br&gt;(os.environ.setdefault)&lt;br&gt;Missing GNEWS_API_KEY → sys.exit(1)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="715" y="90" width="210" height="62" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         SECTION 2: DOMAIN MODELS
    ═══════════════════════════════════════════ -->
    <mxCell id="models_bg" value="&lt;b&gt;2. DOMAIN MODELS (models.py)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=11;fontStyle=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="80" y="185" width="960" height="95" as="geometry" />
    </mxCell>

    <mxCell id="newsquery" value="&lt;b&gt;NewsQuery&lt;/b&gt; — Provider-agnostic request&lt;br&gt;q · language · country&lt;br&gt;from_date · to_date · page&lt;br&gt;page_size · sort_by" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="110" y="198" width="210" height="72" as="geometry" />
    </mxCell>

    <mxCell id="article_model" value="&lt;b&gt;SpaceFlight&lt;/b&gt; — Normalized Article (every provider maps to this shape)&lt;br&gt;provider · provider_article_id · title · url · summary · content&lt;br&gt;authors[ ] · published_at · source_name · language · category&lt;br&gt;&lt;i&gt;raw: dict  ← original API payload preserved for debugging / future extraction&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="345" y="198" width="680" height="72" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         SECTION 3: TRANSPORT / RELIABILITY
    ═══════════════════════════════════════════ -->
    <mxCell id="transport_bg" value="&lt;b&gt;3. TRANSPORT &amp;amp; RELIABILITY (transport.py)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=11;fontStyle=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="80" y="295" width="960" height="110" as="geometry" />
    </mxCell>

    <mxCell id="httpclient" value="&lt;b&gt;HttpClient&lt;/b&gt; (Protocol)&lt;br&gt;requests.Session&lt;br&gt;Injected into providers&lt;br&gt;Swappable in tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="110" y="308" width="155" height="80" as="geometry" />
    </mxCell>

    <mxCell id="ratelimiter" value="&lt;b&gt;RateLimiter&lt;/b&gt;&lt;br&gt;Enforces min delay between calls&lt;br&gt;One instance per provider&lt;br&gt;time.monotonic() tracking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="285" y="308" width="200" height="80" as="geometry" />
    </mxCell>

    <mxCell id="withretry" value="&lt;b&gt;with_retry()&lt;/b&gt; — Exponential Backoff&lt;br&gt;Up to 3 attempts (configurable via FetchConfig)&lt;br&gt;RETRY: Timeout · ConnectionError · 429 · 500 · 502 · 503 · 504&lt;br&gt;NON-RETRY (4xx other) → raises ArticleFetchError immediately&lt;br&gt;All attempts exhausted → raises ArticleFetchError" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="505" y="300" width="330" height="90" as="geometry" />
    </mxCell>

    <mxCell id="backoff_note" value="Backoff: 2s → 4s → fail" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=center;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="855" y="320" width="170" height="40" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         SECTION 4: PROVIDER COMPONENTS
    ═══════════════════════════════════════════ -->
    <mxCell id="providers_bg" value="&lt;b&gt;4. PROVIDER COMPONENTS (providers/) — one component per API connection&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;fontStyle=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="80" y="420" width="960" height="410" as="geometry" />
    </mxCell>

    <mxCell id="base_provider" value="&lt;b&gt;NewsProvider&lt;/b&gt; ABC (providers/base.py)&lt;br&gt;@abstractproperty  provider_name: str&lt;br&gt;@abstractmethod  fetch(NewsQuery) → SpaceFlight[ ]&lt;br&gt;Raises NewsProviderError on any unrecoverable failure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="290" y="432" width="470" height="72" as="geometry" />
    </mxCell>

    <!-- ── GNews Provider Swimlane ── -->
    <mxCell id="gnews_lane" value="&lt;b&gt;GNewsProvider&lt;/b&gt; (providers/gnews.py)" style="swimlane;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="95" y="520" width="450" height="295" as="geometry" />
    </mxCell>

    <mxCell id="gnews_1" value="① _build_params(NewsQuery) → HTTP params dict&lt;br&gt;token · max · lang · sortby · q · from · to" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="gnews_lane">
      <mxGeometry x="20" y="38" width="410" height="45" as="geometry" />
    </mxCell>

    <mxCell id="gnews_2" value="② rate_limiter.wait()  — enforce per-provider minimum delay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="gnews_lane">
      <mxGeometry x="20" y="93" width="410" height="30" as="geometry" />
    </mxCell>

    <mxCell id="gnews_3" value="③ with_retry(session.get, url, params, timeout)&lt;br&gt;→ GET https://gnews.io/api/v4/search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="gnews_lane">
      <mxGeometry x="20" y="133" width="410" height="45" as="geometry" />
    </mxCell>

    <mxCell id="gnews_4" value="④ response.json() → data['articles'][ ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="gnews_lane">
      <mxGeometry x="20" y="188" width="410" height="30" as="geometry" />
    </mxCell>

    <mxCell id="gnews_5" value="⑤ _parse(raw) → SpaceFlight  [for each article]&lt;br&gt;title · url · description→summary · content (may be truncated)&lt;br&gt;authors=[ ]  (GNews API provides no author field) · raw=original" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="gnews_lane">
      <mxGeometry x="20" y="228" width="410" height="52" as="geometry" />
    </mxCell>

