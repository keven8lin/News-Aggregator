    <!-- ═══════════════════════════════════════════
         ERROR HANDLING (right column)
    ═══════════════════════════════════════════ -->
    <mxCell id="err_bg" value="&lt;b&gt;ERROR HANDLING&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=11;fontStyle=1;opacity=50;" vertex="1" parent="1">
      <mxGeometry x="1060" y="420" width="240" height="410" as="geometry" />
    </mxCell>

    <mxCell id="err_fetch" value="&lt;b&gt;ArticleFetchError&lt;/b&gt;&lt;br&gt;(transport.py)&lt;br&gt;All retry attempts exhausted&lt;br&gt;or non-retriable HTTP status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1070" y="435" width="215" height="65" as="geometry" />
    </mxCell>

    <mxCell id="err_parse" value="&lt;b&gt;ArticleParseError&lt;/b&gt;&lt;br&gt;(providers/base.py)&lt;br&gt;Bad / unexpected API response&lt;br&gt;shape — KeyError or TypeError" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1070" y="515" width="215" height="65" as="geometry" />
    </mxCell>

    <mxCell id="err_provider" value="&lt;b&gt;NewsProviderError&lt;/b&gt;&lt;br&gt;(providers/base.py)&lt;br&gt;Wraps both above&lt;br&gt;Caught by NewsAggregator:&lt;br&gt;→ prints WARNING to stderr&lt;br&gt;→ pipeline continues" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1070" y="595" width="215" height="90" as="geometry" />
    </mxCell>

    <mxCell id="err_report" value="&lt;b&gt;ReportWriteError&lt;/b&gt;&lt;br&gt;(reporter.py)&lt;br&gt;Wraps OSError on disk write&lt;br&gt;→ sys.exit(2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1070" y="700" width="215" height="65" as="geometry" />
    </mxCell>

    <!-- Error hierarchy arrows -->
    <mxCell id="ee1" value="wrapped as" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontColor=#b85450;fontSize=9;" edge="1" source="err_fetch" target="err_provider" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="ee2" value="subclass of" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontColor=#b85450;fontSize=9;" edge="1" source="err_parse" target="err_provider" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         SECTION 5: AGGREGATION
    ═══════════════════════════════════════════ -->
    <mxCell id="agg_bg" value="&lt;b&gt;5. AGGREGATION&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=11;fontStyle=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="80" y="845" width="960" height="100" as="geometry" />
    </mxCell>

    <mxCell id="aggregator" value="&lt;b&gt;NewsAggregator.fetch_all()&lt;/b&gt; (aggregator.py)&lt;br&gt;① Fan-out: calls provider.fetch(query) for each registered provider in registration order&lt;br&gt;② Per-provider query routing via per_provider dict  (Iran query → gnews,  empty query → spaceflight random)&lt;br&gt;③ Fault isolation: catches NewsProviderError → WARNING to stderr, skips provider, pipeline continues&lt;br&gt;④ URL deduplication: _deduplicate() — set-based, first-seen order preserved, later duplicates dropped&lt;br&gt;Output: List[SpaceFlight]  (combined, deduplicated across all providers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="110" y="858" width="890" height="80" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         SECTION 6: TEXT ANALYSIS
    ═══════════════════════════════════════════ -->
    <mxCell id="analysis_bg" value="&lt;b&gt;6. TEXT ANALYSIS (analyzer.py) — pure stateless functions, no I/O, executed per provider slice&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;fontStyle=1;opacity=50;" vertex="1" parent="1">
      <mxGeometry x="80" y="960" width="960" height="165" as="geometry" />
    </mxCell>

    <mxCell id="corpus" value="extract_text_corpus()&lt;br&gt;Concatenate title + summary&lt;br&gt;for all articles → string" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="110" y="975" width="155" height="62" as="geometry" />
    </mxCell>

    <mxCell id="tokenize_box" value="tokenize()&lt;br&gt;lowercase · strip non-alpha&lt;br&gt;split on whitespace&lt;br&gt;drop empty strings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="285" y="975" width="155" height="62" as="geometry" />
    </mxCell>

    <mxCell id="wordfreq_box" value="word_frequency()&lt;br&gt;Counter({word: count})&lt;br&gt;from token list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="460" y="975" width="155" height="62" as="geometry" />
    </mxCell>

    <mxCell id="lwords_box" value="least_common_words_containing_l()&lt;br&gt;Filter words containing 'l'&lt;br&gt;Sort asc by count, then alpha&lt;br&gt;→ Top 5 tuples" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="635" y="970" width="195" height="72" as="geometry" />
    </mxCell>

    <mxCell id="count_auth_box" value="count_authors()&lt;br&gt;Counter({author: count})&lt;br&gt;from articles[].authors[ ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="460" y="1057" width="155" height="58" as="geometry" />
    </mxCell>

    <mxCell id="repeat_auth_box" value="authors_appearing_more_than_once()&lt;br&gt;Filter count &gt; 1&lt;br&gt;Sort desc by count, alpha for ties&lt;br&gt;→ dict{author: count}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="635" y="1052" width="215" height="65" as="geometry" />
    </mxCell>

    <!-- Analysis inner flow -->
    <mxCell id="ai1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="corpus" target="tokenize_box" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="ai2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="tokenize_box" target="wordfreq_box" parent="1">
