    <!-- ── Spaceflight Provider Swimlane ── -->
    <mxCell id="sf_lane" value="&lt;b&gt;SpaceflightNewsProvider&lt;/b&gt; (providers/spaceflight.py)" style="swimlane;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="565" y="520" width="465" height="295" as="geometry" />
    </mxCell>

    <mxCell id="sf_1" value="① query.q set?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sf_lane">
      <mxGeometry x="155" y="35" width="155" height="60" as="geometry" />
    </mxCell>

    <mxCell id="sf_search" value="_fetch_by_search()&lt;br&gt;GET /articles/?search=q&amp;amp;limit=N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sf_lane">
      <mxGeometry x="295" y="108" width="155" height="45" as="geometry" />
    </mxCell>

    <mxCell id="sf_total" value="_fetch_total_count()&lt;br&gt;GET /articles/?limit=1&lt;br&gt;parse response['count']" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sf_lane">
      <mxGeometry x="15" y="108" width="155" height="55" as="geometry" />
    </mxCell>

    <mxCell id="sf_sample" value="random.sample(range(total), n)&lt;br&gt;→ n random offsets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sf_lane">
      <mxGeometry x="15" y="175" width="155" height="45" as="geometry" />
    </mxCell>

    <mxCell id="sf_offset" value="rate_limit + with_retry&lt;br&gt;GET /articles/?limit=1&amp;amp;offset=N&lt;br&gt;(one request per random offset)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sf_lane">
      <mxGeometry x="180" y="168" width="175" height="55" as="geometry" />
    </mxCell>

    <mxCell id="sf_parse" value="_parse(raw) → SpaceFlight&lt;br&gt;id→provider_article_id · title · url · summary&lt;br&gt;authors[].name extracted · news_site→source_name&lt;br&gt;content='' (API does not provide full text) · raw=original" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sf_lane">
      <mxGeometry x="15" y="235" width="430" height="50" as="geometry" />
    </mxCell>

    <!-- Spaceflight inner flow arrows -->
    <mxCell id="si1" value="YES (q set)" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="sf_1" target="sf_search" parent="sf_lane">
