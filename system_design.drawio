    </mxCell>
    <mxCell id="ai3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="wordfreq_box" target="lwords_box" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="ai4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="count_auth_box" target="repeat_auth_box" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════
         SECTION 7: REPORT GENERATION
    ═══════════════════════════════════════════ -->
    <mxCell id="reporter_bg" value="&lt;b&gt;7. REPORT GENERATION (reporter.py) — one report written per provider&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#9673a6;verticalAlign=top;fontSize=11;fontStyle=1;opacity=50;" vertex="1" parent="1">
      <mxGeometry x="80" y="1135" width="960" height="160" as="geometry" />
    </mxCell>

    <mxCell id="build_report_box" value="&lt;b&gt;build_report()&lt;/b&gt;&lt;br&gt;Assembles output dict:&lt;br&gt;• generated_at (ISO-8601, injectable for tests)&lt;br&gt;• article_count&lt;br&gt;• articles[ ]: provider · id · title · url&lt;br&gt;    source_name · published_at · authors · raw&lt;br&gt;• analysis.least_common_words_containing_l[ ]&lt;br&gt;• analysis.authors_appearing_more_than_once[ ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="110" y="1150" width="295" height="130" as="geometry" />
    </mxCell>

    <mxCell id="filename_box" value="output_filename()&lt;br&gt;summary_results_quotes&lt;br&gt;_YYYYMMDDHHMMSS.json&lt;br&gt;timestamp injectable for tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#9673a6;" vertex="1" parent="1">
